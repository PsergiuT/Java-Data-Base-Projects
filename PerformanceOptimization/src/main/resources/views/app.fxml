<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.AppController"
            prefHeight="400.0" prefWidth="600.0">

    <HBox spacing="10.0" alignment="CENTER">
        <Button fx:id="benchmarkButton" text="N + 1 Lazy" onAction="#handleNplus1Lazy" />
        <Button fx:id="leakButton" text="N + 1 Eager" onAction="#handleNplus1Eager" />
        <Button fx:id="benchmark" text="Without index" onAction="#handleBenchmarkWithoutIndex" />
        <Button fx:id="leak" text="With index" onAction="#handleBenchmarkIndex" />
    </HBox>

</AnchorPane>
